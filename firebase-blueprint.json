{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user of the platform.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The URL of the user's profile picture."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The role of the user."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "The time the user account was created."
        }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Creative": {
      "title": "Creative",
      "description": "An AI-generated creative image and copy.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who generated this creative."
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the generated image."
        },
        "headline": {
          "type": "string",
          "description": "The headline of the creative."
        },
        "body": {
          "type": "string",
          "description": "The body text of the creative."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "The time the creative was generated."
        }
      },
      "required": ["userId", "imageUrl", "headline", "body", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global site settings managed by admins.",
      "type": "object",
      "properties": {
        "siteName": {
          "type": "string",
          "description": "The name of the site."
        },
        "maintenanceMode": {
          "type": "boolean",
          "description": "Whether the site is in maintenance mode."
        }
      },
      "required": ["siteName", "maintenanceMode"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and roles."
    },
    "/creatives/{creativeId}": {
      "schema": {
        "$ref": "#/entities/Creative"
      },
      "description": "Stores generated creatives."
    },
    "/settings/{settingId}": {
      "schema": {
        "$ref": "#/entities/Settings"
      },
      "description": "Stores global site settings."
    }
  }
}
